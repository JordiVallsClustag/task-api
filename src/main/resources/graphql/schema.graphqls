type Query {
    findAllTasks(categoryId: ID, deleted: Boolean, offset: Int = 0, limit: Int = 10): TaskPage
    taskById(id: ID!): Task
    categories(offset: Int = 0, limit: Int = 10): CategoryPage
    categoryById(id: ID!): Category
}

type Mutation {
    createTask(input: TaskInput!): Task
    toggleTask(id: ID!): Task
    updateTask(id: ID!, input: TaskUpdateInput!): Task
    toggleDeleteTask(id: ID!): Task
    createCategory(input: CategoryInput!): Category
    updateCategory(id: ID!, input: CategoryUpdateInput!): Category
    toggleDeleteCategory(id: ID!): Category
}

input TaskInput {
    title: String!
    description: String
    completed: Boolean
    categoryId: ID
}

input TaskUpdateInput {
    title: String
    description: String
    completed: Boolean
    categoryId: ID
}

type Task {
    id: ID
    title: String
    description: String
    completed: Boolean
    categoryId: ID
    category: Category
    deleted: Boolean
    createdAt: String
    updatedAt: String
}

type PageInfo {
    offset: Int
    limit: Int
    totalCount: Int
    hasNextPage: Boolean
    hasPreviousPage: Boolean
}

type TaskPage {
    items: [Task]
    pageInfo: PageInfo
}

type CategoryPage {
    items: [Category]
    pageInfo: PageInfo
}

input CategoryInput {
    name: String!
}

input CategoryUpdateInput {
    name: String
    isActive: Boolean
}

type Category {
    id: ID
    name: String
    isActive: Boolean
}
